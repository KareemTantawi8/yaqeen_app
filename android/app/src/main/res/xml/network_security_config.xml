<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        just_audio on Android proxies audio through a local HTTP server at 127.0.0.1.
        Radio streams from mp3quran.net also use plain HTTP.
        Both require cleartext to be permitted.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
